# =====================================================================
# Tempo AI Hub — environment variables
# Copy this file to `.env.local` and fill in real values.
# =====================================================================

# ----- Dev bypass (skip login while editing UI) --------------------------
# Set to "true" to auto-login as a fake admin user. Entity reads return empty
# arrays when Supabase isn't configured, so the whole SPA renders. Never set
# this in production.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false

# ----- Supabase (required when DEV_BYPASS_AUTH=false) --------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...           # public anon key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...               # server-only, NEVER expose

# ----- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- AI provider (pick ONE; OpenRouter is the default) -----------------
LLM_PROVIDER=openrouter                                # openrouter | openai | gemini

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-exp:free

# OpenAI (only used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Google Gemini (only used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# Poe by Quora (OpenAI-compatible) — one key for many bots (GPT/Claude/Gemini/…)
# Get a key at https://poe.com/api_key · model = the Poe bot name (e.g. GPT-4o-mini)
POE_API_KEY=
POE_DEFAULT_MODEL=GPT-4o-mini

# ----- Payments (optional) ----------------------------------------------
# Leave BOTH blank → payment runs in "demo" mode (full flow, NO real charge).
# Omise = recommended for Thailand (PromptPay + cards). Get keys at omise.co.
OMISE_SECRET_KEY=                                      # skey_test_... / skey_live_...
OMISE_PUBLIC_KEY=                                      # pkey_... (for Omise.js card tokens, next phase)
# Stripe (optional, international cards)
STRIPE_SECRET_KEY=                                     # sk_test_... / sk_live_...
STRIPE_WEBHOOK_SECRET=                                 # whsec_... (verify webhook signature)
# After deploy, point the provider's webhook at:
#   Omise  → https://YOUR-DOMAIN/api/payments/webhook?provider=omise
#   Stripe → https://YOUR-DOMAIN/api/payments/webhook?provider=stripe
